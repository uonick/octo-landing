---
import { Image } from 'astro:assets'
import appIcon from '@/assets/images/app-icon.png'
---

<header class="sticky top-0 z-50 bg-canvas/70 backdrop-blur-xl">
  <div class="container mx-auto max-w-6xl px-5 xl:px-0">
    <nav class="flex h-16 items-center justify-between">
      <a href="/" class="flex items-center gap-2.5 text-ink">
        <Image
          src={appIcon}
          alt="OctoWorkspace"
          width={32}
          height={32}
          quality={90}
          format="webp"
          loading="eager"
          class="h-8 w-8 rounded-xl"
        />
        <span class="text-sm font-bold tracking-tight">OctoWorkspace</span>
      </a>

      <ul
        class="hidden flex-1 items-center justify-center gap-8 text-sm font-medium text-ink-subtle md:flex"
      >
        <li>
          <a class="rounded-full px-3 py-1.5 transition-colors hover:bg-surface-2 hover:text-ink" href="/#features">Возможности</a>
        </li>
        <li>
          <a class="rounded-full px-3 py-1.5 transition-colors hover:bg-surface-2 hover:text-ink" href="/#faqs">Вопросы и ответы</a>
        </li>
        <li>
          <a
            class="rounded-full px-3 py-1.5 transition-colors hover:bg-surface-2 hover:text-ink"
            href="https://github.com/uonick/octo-workspace/releases"
          >
            Релизы
          </a>
        </li>
      </ul>

      <a
        class="hidden items-center gap-2 rounded-2xl bg-surface-2 px-4 py-2 text-sm font-medium text-ink transition-all hover:-translate-y-0.5 hover:bg-surface-3 md:flex"
        href="https://github.com/uonick/octo-workspace"
        target="_blank"
        rel="noreferrer"
      >
        <svg viewBox="0 0 24 24" class="h-4 w-4" fill="currentColor">
          <path
            d="M12 .5C5.65.5.5 5.65.5 12c0 5.09 3.29 9.4 7.86 10.93.57.1.78-.25.78-.55 0-.27-.01-1.17-.02-2.12-3.2.7-3.88-1.36-3.88-1.36-.52-1.34-1.28-1.7-1.28-1.7-1.05-.71.08-.7.08-.7 1.16.08 1.77 1.19 1.77 1.19 1.03 1.76 2.71 1.25 3.37.96.1-.75.4-1.25.73-1.54-2.55-.29-5.24-1.28-5.24-5.68 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.18a10.9 10.9 0 0 1 5.74 0c2.19-1.49 3.15-1.18 3.15-1.18.62 1.58.23 2.75.11 3.04.74.8 1.18 1.83 1.18 3.08 0 4.41-2.7 5.39-5.26 5.67.41.36.78 1.06.78 2.13 0 1.54-.01 2.78-.01 3.16 0 .3.2.66.79.55A11.5 11.5 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"
          ></path>
        </svg>
        GitHub
      </a>
    </nav>
  </div>
</header>
