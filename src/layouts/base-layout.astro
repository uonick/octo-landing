---
import '@/styles/global.css'

type Props = {
  title?: string
  description?: string
}

const {
  title = 'Бесплатное приложение для работы на фрилансе',
  description = 'OctoWorkspace – бесплатное приложение для работы на фрилансе',
} = Astro.props
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="бесплатное приложение, бесплатная оффлайн CRM, CRM для фрилансеров, CRM для дизайнеров, CRM для программистов, оффлайн CRM"
    />
    <meta name="author" content="uonick" />
    <meta name="copyright" content="© uonick" />
    <meta name="robots" content="index, follow" />
    <meta name="rating" content="general" />
    <meta name="apple-mobile-web-app-title" content="OctoWorkspace" />
    <meta name="application-name" content="OctoWorkspace" />
    <meta name="msapplication-TileColor" content="#5e6ad2" />
    <meta name="theme-color" content="#010102" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://octows.ru/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://octows.ru/img/screenshot.webp" />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://octows.ru/" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://octows.ru/img/screenshot.webp" />
    <meta property="vk:image" content="https://octows.ru/img/screenshot.webp" />

    <meta name="yandex-verification" content="91ff39d57ea6e7cd" />

    <link rel="sitemap" href="/sitemap.xml" />
  </head>
  <body class="bg-canvas scrollbar antialiased">
    <slot />

    <script type="text/javascript" is:inline>
      ;(function (m, e, t, r, i, k, a) {
        m[i] =
          m[i] ||
          function () {
            (m[i].a = m[i].a || []).push(arguments)
          }
        m[i].l = 1 * new Date()
        for (var j = 0; j < document.scripts.length; j++) {
          if (document.scripts[j].src === r) {
            return
          }
        }
        ;(k = e.createElement(t)), (a = e.getElementsByTagName(t)[0])
        k.async = 1
        k.src = r
        a.parentNode.insertBefore(k, a)
      })(window, document, 'script', 'https://mc.yandex.ru/metrika/tag.js', 'ym')
      ym(95394981, 'init', {
